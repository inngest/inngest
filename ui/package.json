{
  "name": "inngest-ui",
  "scripts": {
    "dev:new-dashboard": "pnpm run --filter @inngest/new-dashboard dev",
    "dev:dev-server-ui": "pnpm run --filter @inngest/dev-server-ui dev",
    "format": "prettier . --write",
    "preinstall": "npx only-allow pnpm",
    "prepare": "cd .. && husky install ./ui/.husky"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "eslint": "10.3.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.4",
    "postcss-nesting": "14.0.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "0.8.0"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@11.1.1",
  "private": true
}
