{
  "name": "inngest-ui",
  "scripts": {
    "dev:new-dashboard": "pnpm run --filter @inngest/new-dashboard dev",
    "dev:dev-server-ui": "pnpm run --filter @inngest/dev-server-ui dev",
    "format": "prettier . --write",
    "preinstall": "npx only-allow pnpm",
    "prepare": "cd .. && husky install ./ui/.husky"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^3.7.2",
    "eslint": "^9.31.0",
    "husky": "^8.0.2",
    "lint-staged": "^15.5.0",
    "postcss-nesting": "^13.0.2",
    "prettier": "^2.8.7",
    "prettier-plugin-tailwindcss": "^0.2.7",
    "turbo": "^2.9.14"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "packageManager": "pnpm@11.8.0",
  "private": true
}
