{
  "name": "@inngest/api-docs",
  "description": "Inngest API Documentation",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm generate && tsc --noEmit && vite build --mode=production",
    "generate": "tsx scripts/generate-docs.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.1",
    "fumadocs-core": "^16.0.0",
    "fumadocs-mdx": "^14.0.0",
    "fumadocs-openapi": "^10.0.0",
    "fumadocs-ui": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^3.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@tanstack/eslint-config": "^0.3.0",
    "@types/mdx": "^2.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^5.1.3",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.19.0",
    "yaml": "^2.0.0",
    "typescript": "^5.8.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.5"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.18.2"
}
