{
  "name": "@inngest/dashboard",
  "description": "Inngest Dashboard",
  "license": "UNLICENSED",
  "homepage": "https://app.inngest.com/",
  "repository": {
    "type": "git",
    "url": "https://github.com/inngest/inngest.git",
    "directory": "ui/apps/dashboard"
  },
  "author": "Inngest Inc. <info@inngest.com> (https://inngest.com/)",
  "main": "n/a",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "concurrently --prefix-colors \"green.inverse,magenta.inverse,blue.inverse\" pnpm:dev:*",
    "dev:vite": "vite dev",
    "dev:graphql-codegen": "graphql-codegen -w -r dotenv/config",
    "build": "pnpm build:tsc && pnpm build:graphql-codegen && pnpm build:vite",
    "build:tsc": "tsc --noEmit",
    "build:graphql-codegen": "if test \"$VERCEL_ENV\" = \"production\"; then pnpm graphql-codegen;  fi",
    "build:vite": "vite build",
    "graphql-codegen": "graphql-codegen -r dotenv/config",
    "start": "node .output/server/index.mjs",
    "start:local": "PORT=5173 node -r dotenv/config .output/server/index.mjs dotenv_config_path=.env.local",
    "format": "prettier --write src",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@clerk/tanstack-react-start": "^0.29.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@headlessui/react": "^2.2.10",
    "@headlessui/tailwindcss": "^0.2.0",
    "@inngest/agent-kit": "^0.13.2",
    "@inngest/realtime": "0.4.7",
    "@inngest/use-agent": "^0.4.0",
    "@launchdarkly/node-server-sdk": "^9.0.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@remixicon/react": "^4.7.0",
    "@segment/analytics-next": "^1.81.1",
    "@sentry/tanstackstart-react": "^10.26.0",
    "@sindresorhus/slugify": "^3.0.0",
    "@stripe/react-stripe-js": "^6.0.0",
    "@stripe/stripe-js": "^9.0.0",
    "@tanstack/eslint-config": "^0.4.0",
    "@tanstack/nitro-v2-vite-plugin": "^1.154.7",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-router-devtools": "^1.158.1",
    "@tanstack/react-router-ssr-query": "^1.158.1",
    "@tanstack/react-start": "^1.158.1",
    "@tanstack/react-table": "^8.21.3",
    "@team-plain/typescript-sdk": "^3.0.1",
    "@unpic/react": "^1.0.1",
    "@urql/core": "^6.0.1",
    "@urql/exchange-auth": "^3.0.0",
    "@urql/exchange-request-policy": "^2.0.0",
    "@urql/exchange-retry": "^2.0.0",
    "change-case": "^5.4.4",
    "cmdk": "^1.0.4",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.0.0",
    "graphql": "16.14.0",
    "graphql-request": "^7.0.0",
    "inngest": "^4.2.6",
    "ky": "^2.0.0",
    "launchdarkly-react-client-sdk": "^3.0.8",
    "mustache": "^4.2.0",
    "next-themes": "^0.4.6",
    "quickjs-emscripten": "^0.32.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.0.0",
    "react-use": "^17.6.0",
    "recharts": "^2.4.3",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.0",
    "sql-formatter": "^15.7.1",
    "srvx": "0.11.15",
    "ulid": "^3.0.0",
    "urql": "^5.0.2",
    "uuid": "^14.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "7.0.0",
    "@graphql-codegen/client-preset": "6.0.0",
    "@tailwindcss/container-queries": "0.1.1",
    "@types/mustache": "4.2.6",
    "@types/node": "24.12.4",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "15.5.13",
    "@typescript-eslint/eslint-plugin": "8.59.3",
    "@typescript-eslint/parser": "8.59.3",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.5.0",
    "concurrently": "9.2.1",
    "eslint": "10.3.0",
    "eslint-plugin-react-hooks": "5.2.0",
    "postcss": "8.5.14",
    "prettier": "3.8.3",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.59.3",
    "vite": "8.0.12",
    "vite-plugin-svgr": "5.2.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.6"
  },
  "packageManager": "pnpm@11.1.1",
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  }
}
