{
  "name": "@inngest/dev-server-ui",
  "description": "Inngest Development Server UI",
  "license": "UNLICENSED",
  "homepage": "https://github.com/inngest/inngest/tree/main/ui/apps/dev-server-ui#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/inngest/inngest.git",
    "directory": "ui/apps/dev-server-ui"
  },
  "author": "Inngest Inc. <info@inngest.com> (https://inngest.com/)",
  "main": "n/a",
  "type": "module",
  "scripts": {
    "codegen": "graphql-codegen --config codegen.ts",
    "dev": "pnpm i && concurrently --prefix-colors \"green.inverse,magenta.inverse,blue.inverse\" pnpm:dev:*",
    "dev:vite": "vite dev",
    "dev:codegen": "nodemon -w ../pkg/coreapi -e graphql -x 'pnpm codegen'",
    "build": "graphql-codegen --config codegen.ts && tsc --noEmit && vite build --mode=production",
    "preview": "vite preview",
    "format": "prettier --write src",
    "lint": "eslint src --report-unused-disable-directives --max-warnings 0",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "preinstall": "npx only-allow pnpm"
  },
  "dependencies": {
    "@headlessui/react": "^1.7.17",
    "@inngest/components": "workspace:*",
    "@reduxjs/toolkit": "^1.9.0",
    "@remixicon/react": "^4.2.0",
    "@rtk-query/graphql-request-base-query": "^2.2.0",
    "@tanstack/react-query": "^5.66.5",
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-router-devtools": "^1.158.1",
    "@tanstack/react-start": "^1.158.1",
    "@tanstack/react-table": "^8.21.3",
    "graphql": "^16.8.1",
    "graphql-request": "^7.0.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.0.0",
    "sonner": "^2.0.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "6.2.1",
    "@graphql-codegen/typescript": "5.0.9",
    "@graphql-codegen/typescript-operations": "5.0.9",
    "@graphql-codegen/typescript-rtk-query": "4.0.0",
    "@inngest/components": "workspace:*",
    "@tanstack/eslint-config": "0.4.0",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@vitejs/plugin-react": "6.0.1",
    "autoprefixer": "10.4.27",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-plugin-react-hooks": "5.2.0",
    "nodemon": "3.1.14",
    "postcss": "8.5.9",
    "prettier": "3.8.2",
    "tailwindcss": "3.4.19",
    "typescript": "5.9.3",
    "typescript-eslint": "8.58.1",
    "vite": "8.0.8",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.4"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.33.0",
  "private": true
}
