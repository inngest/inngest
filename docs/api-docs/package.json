{
  "name": "@inngest/api-docs",
  "description": "Inngest API Documentation",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "pnpm generate && tsc --noEmit && vite build --mode=production",
    "generate": "tsx scripts/generate-docs.ts",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "format": "prettier --write src",
    "preinstall": "npx only-allow pnpm",
    "postinstall": "fumadocs-mdx"
  },
  "dependencies": {
    "@tanstack/react-router": "^1.158.1",
    "@tanstack/react-start": "^1.158.1",
    "fumadocs-core": "^16.0.0",
    "fumadocs-mdx": "^14.0.0",
    "fumadocs-openapi": "10.8.1",
    "fumadocs-ui": "^16.0.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^4.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.4",
    "@tanstack/eslint-config": "0.4.0",
    "@types/mdx": "2.0.13",
    "@types/node": "24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.1",
    "tailwindcss": "4.2.4",
    "tsx": "4.21.0",
    "yaml": "2.8.4",
    "typescript": "5.9.3",
    "vite": "8.0.10",
    "vite-tsconfig-paths": "6.1.1"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "11.x"
  },
  "packageManager": "pnpm@11.0.6"
}
